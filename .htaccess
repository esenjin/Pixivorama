# Protège config.php, settings.json et tous les fichiers JSON de galeries
<FilesMatch "^(config\.php|settings\.json)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protège les fichiers JSON dans galleries/
<FilesMatch "\.json$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protège le dossier private/ (accès direct bloqué sauf via PHP authentifié)
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloque l'accès direct aux .php dans private/ si pas de session admin
    # (la vérification de session est gérée par PHP lui-même)
</IfModule>
